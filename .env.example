DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=your-application-client-id
GUILD_ID=your-test-guild-id

# Shared secret with INXX's /api/bot/* routes. Must match DISCORD_BOT_API_SECRET in INXX's .env.
DISCORD_BOT_API_SECRET=replace_with_a_long_random_secret
# Base URL of the INXX web app (server-to-server, no trailing slash).
INXX_API_BASE_URL=http://localhost:3000
# Base URL guild members use in their browser, linked from bot messages.
INXX_WEB_BASE_URL=http://localhost:3000

# Optional exact prefix aliases: ./보석 and ./보석강화.
# When true, enable the Message Content intent in the Discord Developer Portal.
INXX_ENABLE_PREFIX_COMMANDS=false
